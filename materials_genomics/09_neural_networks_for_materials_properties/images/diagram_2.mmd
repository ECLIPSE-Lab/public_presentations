graph TD
    A((Atom i)) --- B((Atom j))
    B --- C((Atom k))
    A --- C
    Bij[Bond i-j]
    Bjk[Bond j-k]
    Bik[Bond i-k]
    Bij -- "angle (i,j,k)" --- Bjk
    style Bij fill:#fbb,stroke:#333,color:#000
    style Bjk fill:#fbb,stroke:#333,color:#000
    style Bik fill:#fbb,stroke:#333,color:#000
